rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return signedIn() && request.auth.uid == ownerId;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    function isSuperAdmin() {
      return signedIn()
        && request.auth.token.email == 'superadmin@theavenue.org';
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /admins/{userId} {
      allow read: if isSuperAdmin() || (signedIn() && request.auth.token.email == userId);
      allow create, update, delete: if isSuperAdmin();
    }

    match /events/{eventId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;

      allow read: if signedIn()
        && (resource.data.privacy == 'public' || resource.data.ownerId == request.auth.uid);

      allow update, delete: if isOwner(resource.data.ownerId);
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() || isSuperAdmin();
    }
  }
}