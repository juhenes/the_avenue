rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isOwner(ownerId) {
      return signedIn() && request.auth.uid == ownerId;
    }
    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }
    function isSuperAdmin() {
      return signedIn()
        && request.auth.token.email == 'superadmin@theavenue.org';
    }
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    match /admins/{userId} {
      allow read: if isSuperAdmin() || (signedIn() && request.auth.token.email == userId);
      allow create, update, delete: if isSuperAdmin();
    }
    match /events/{eventId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow read: if signedIn()
        && (resource.data.privacy == 'public' || resource.data.ownerId == request.auth.uid);
      allow update, delete: if isOwner(resource.data.ownerId);
    }
    match /announcements/{announcementId} {
      // Admins/superadmin can read everything (get or list, archived or not).
      // Everyone else can only read non-archived announcements — and for list
      // queries, the client MUST filter with where('archived', '==', false)
      // or Firestore will reject the whole query as unprovable.
      allow read: if isAdmin() || isSuperAdmin() || resource.data.archived != true;

      allow create: if (isAdmin() || isSuperAdmin())
        && request.resource.data.keys().hasAll(['title', 'description', 'createdAt', 'priority', 'author', 'pinned', 'archived'])
        && request.resource.data.archived is bool;

      allow update: if isAdmin() || isSuperAdmin();

      allow delete: if isAdmin() || isSuperAdmin();
    }
  }
}